<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_widget"
    android:orientation="vertical"
    android:padding="10dp">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingBottom="6dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/app_name"
            android:textColor="#FF333333"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvPendingCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FF999999"
            android:textSize="11sp" />
    </LinearLayout>

    <!-- 今日待办（每日任务） -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="3dp"
        android:paddingTop="2dp"
        android:text="@string/section_today"
        android:textColor="#FF555555"
        android:textSize="11sp" />

    <ListView
        android:id="@+id/dailyTaskList"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:divider="#1A000000"
        android:dividerHeight="0.5dp"
        android:scrollbars="none" />

    <!-- Empty state for daily -->
    <TextView
        android:id="@+id/tvDailyEmpty"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:text="@string/no_tasks"
        android:textColor="#FF999999"
        android:textSize="12sp"
        android:visibility="invisible" />

    <!-- 分隔线 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginVertical="4dp"
        android:background="#1A000000" />

    <!-- 未来日程（日程任务） -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="3dp"
        android:paddingTop="2dp"
        android:text="@string/section_future"
        android:textColor="#FF555555"
        android:textSize="11sp" />

    <ListView
        android:id="@+id/scheduledTaskList"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:divider="#1A000000"
        android:dividerHeight="0.5dp"
        android:scrollbars="none" />

    <!-- Empty state for scheduled -->
    <TextView
        android:id="@+id/tvScheduledEmpty"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:text="@string/widget_empty"
        android:textColor="#FF999999"
        android:textSize="12sp"
        android:visibility="invisible" />

</LinearLayout>
